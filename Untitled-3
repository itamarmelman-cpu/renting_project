/* Responsive Design for Mobile Devices */
@media (max-width: 768px) {
    .cart-item {
        flex-direction: column;
        align-items: stretch;
        padding: var(--space-5);
    }
    
    /* Item Icon Wrapper */
    .cart-item-icon {
        font-size: 2.5rem;
        background-color: var(--palette-mustard);
        width: 70px;
        height: 70px;
        min-width: 70px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        flex-shrink: 0;
        overflow: hidden;
        padding: var(--space-1);
    }

    /* Cart Item Image Restriction */
    .cart-item-icon img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }
    
    .cart-item-controls {
        align-self: flex-start;
        margin-top: var(--space-2);
    }
    
    .cart-item-total {
        text-align: right;
        margin-top: var(--space-3);
    }
    
    .cart-item-remove {
        position: absolute;
        top: var(--space-4);
        left: var(--space-4);
    }
    
    .cart-summary {
        justify-content: center;
    }
    
    .cart-actions {
        flex-direction: column-reverse;
    }
    
    .cart-actions .btn {
        width: 100%;
        justify-content: center;
    }
} /* The missing closing bracket is placed here! */

/* Ecommerce Footer Styles */
.ecommerce-footer {
    background-color: var(--color-header-bg);
    color: #ffffff;
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-8) var(--space-4);
    margin-top: var(--space-8);
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
}

.footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-6);
    border-bottom: 1px solid var(--color-ink-soft);
    padding-bottom: var(--space-5);
    margin-bottom: var(--space-4);
}

.footer-brand p {
    color: var(--palette-teal);
    font-size: var(--text-sm);
    line-height: 1.6;
    max-width: 90%;
}

.footer-links h3, .footer-info h3 {
    color: var(--palette-mustard);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    margin-bottom: var(--space-4);
}

.footer-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
}

.footer-nav a {
    color: #ffffff;
    font-size: var(--text-sm);
    transition: color var(--duration) var(--ease), transform var(--duration) var(--ease);
    width: fit-content;
}

.footer-nav a:hover {
    color: var(--palette-coral);
    transform: translateX(-5px);
}

.footer-info p {
    color: #ffffff;
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
}

.footer-info .team-names {
    color: var(--palette-teal);
    font-weight: 500;
    line-height: 1.8;
}

.footer-bottom {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: var(--space-2);
}

.copyright {
    color: var(--color-ink-muted);
    font-size: var(--text-xs);
    text-align: center;
}

@media (max-width: 768px) {
    .ecommerce-footer {
        padding: var(--space-5);
    }
    
    .footer-grid {
        grid-template-columns: 1fr;
        gap: var(--space-5);
    }
}

.footer-brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
}

.brand-description {
    color: var(--palette-teal);
    font-size: var(--text-sm);
    line-height: 1.6;
    max-width: 90%;
    margin: 0;
    padding: 0;
}


